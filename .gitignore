# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# dev server logs
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# extracted planning materials (keep originals, ignore unzipped)
/example/_extracted/
/example/_frontmatter/
/example/_slides.txt
/example/_frontmatter.txt

# 무거운 작업 자료 / 사용자 스샷 / 캐시
/example
/report
/data
0001.png
*.bak.*
.claude/
/npm-cache
/npm-global
/.next/dev/

# Claude / settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# QA verification artifacts (throwaway, regenerated by tools/*.mjs)
/tools/hub-verification/
/tools/mobile-check/
/tools/audit-report.json
